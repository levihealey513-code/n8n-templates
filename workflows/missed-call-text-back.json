        "html": "=<div style=\"font-family:'Helvetica Neue',Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;color:#0a0f1e;\">\n<h2 style=\"color:#0057FF;\">📞 Missed Call — Follow Up Now</h2>\n<table style=\"border-collapse:collapse;width:100%;margin:16px 0;\">\n<tr><td style=\"padding:8px 12px;border:1px solid #eee;font-weight:bold;\">Name</td><td style=\"padding:8px 12px;border:1px solid #eee;\">{{ $('Set Call Data').item.json.contactName }}</td></tr>\n<tr><td style=\"padding:8px 12px;border:1px solid #eee;font-weight:bold;\">Phone</td><td style=\"padding:8px 12px;border:1px solid #eee;\"><a href=\"tel:{{ $('Set Call Data').item.json.contactPhone }}\">{{ $('Set Call Data').item.json.contactPhone }}</a></td></tr>\n<tr><td style=\"padding:8px 12px;border:1px solid #eee;font-weight:bold;\">Call Time</td><td style=\"padding:8px 12px;border:1px solid #eee;\">{{ $('Check Business Hours').item.json.formattedTime }} EST</td></tr>\n<tr><td style=\"padding:8px 12px;border:1px solid #eee;font-weight:bold;\">Auto-text sent</td><td style=\"padding:8px 12px;border:1px solid #eee;\">✅ Yes ({{ $('Check Business Hours').item.json.isBusinessHours ? 'Business hours' : 'After hours' }} template)</td></tr>\n</table>\n<p style=\"color:#e74c3c;font-weight:700;\">⏰ 30 minutes have passed — follow up now!</p>\n</div>",
